{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "WebWorker"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["@cloudflare/workers-types", "node"],
    "paths": {
      "@/*": ["./worker/src/*"]
    }
  },
  "include": ["worker/src/**/*.ts", "worker/test/**/*.ts", "vitest.config.ts"]
}
